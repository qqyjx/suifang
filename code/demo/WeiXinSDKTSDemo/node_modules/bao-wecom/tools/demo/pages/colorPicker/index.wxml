<!--pages/colorPicker/index.wxml-->
<view class="card-c">
    <view class="label-c">默认</view>
    <view class="form-item">
        <view class="color-p">
            <view class="label">默认</view>
            <view class="val" data-name="color" catch:tap="showColorPicker">
                <view class="color" style="background-color: {{color.hex}};" wx:if="{{color.hex}}">{{color.hex}}</view>
                <view class="placeholder" wx:else>请选择</view>
            </view>
        </view>
    </view>
    <view class="label-c">color="{{initColor}}"</view>
    <view class="form-item">
        <view class="color-p">
            <view class="label">初始化颜色</view>
            <view class="val" data-name="color1" data-color="{{color1.hex}}" catch:tap="showColorPicker">
                <view class="color" style="background-color: {{color1.hex}};" wx:if="{{color1.hex}}">{{color1.hex}}</view>
                <view class="placeholder" wx:else>请选择</view>
            </view>
        </view>
    </view>
    <view class="label-c">title="请选择颜色"</view>
    <view class="form-item">
        <view class="color-p">
            <view class="label">设置标题</view>
            <view class="val" data-name="color2" data-color="{{color2.hex}}" data-title="请选择颜色" catch:tap="showColorPicker">
                <view class="color" style="background-color: {{color2.hex}};" wx:if="{{color2.hex}}">{{color2.hex}}</view>
                <view class="placeholder" wx:else>请选择</view>
            </view>
        </view>
    </view>
    <view class="label-c">commonColor= "#000000,#ffffff,#ff0000,#ffa500,#00ff00,#0000ff,#ff00ff,#00ffff,#ffff00,#70db93,#cccccc,#999999"</view>
    <view class="form-item">
        <view class="color-p">
            <view class="label">设置常用颜色，最多12个</view>
            <view class="val" data-name="color2" data-color="{{color2.hex}}" data-title="请选择颜色" catch:tap="showColorPicker">
                <view class="color" style="background-color: {{color2.hex}};" wx:if="{{color2.hex}}">{{color2.hex}}</view>
                <view class="placeholder" wx:else>请选择</view>
            </view>
        </view>
    </view>
</view>
<color-picker show="{{isShowColor}}" bindconfirm="colorConfirm" color="{{initColor}}" commonColor="{{commonColor}}" title="{{title}}" bindcancel="colorCancel" bindmask="colorCancel"></color-picker>