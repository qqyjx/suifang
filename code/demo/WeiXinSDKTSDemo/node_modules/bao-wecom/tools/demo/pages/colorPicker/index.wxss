.card-c {
  background-color: #dfdfdf;
}
.card-c .label-c {
  font-size: 14px;
  line-height: 30px;
  padding: 0 10px;
  word-break: break-all;
}
.card-c .form-item {
  background-color: #fff;
}
.card-c .form-item .color-p {
  height: 40px;
  border-bottom: 1px solid #dfdfdf;
  background-color: #fff;
  display: flex;
  align-items: center;
  padding: 0 10px;
}
.card-c .form-item .color-p .label {
  font-size: 14px;
}
.card-c .form-item .color-p .val {
  display: flex;
  flex: 1;
  justify-content: flex-end;
  font-size: 14px;
}
.card-c .form-item .color-p .val .color {
  border: 1px solid #ccc;
  height: 25px;
  width: 60px;
  line-height: 25px;
  text-align: center;
}
.card-c .form-item .color-p .val .placeholder {
  color: #999;
}
