page {
  padding: 20px;
  box-sizing: border-box;
}
page .fun-item-c {
  height: 40px;
  padding: 0 16px;
  display: flex;
  align-items: center;
  font-size: 14px;
  margin-bottom: 10px;
  border-radius: 20px;
  position: relative;
  background-color: #efefef;
}
page .fun-item-c::after {
  content: "";
  position: absolute;
  right: 15px;
  top: 50%;
  transform: translateY(-50%) rotate(45deg);
  border-top: 2px solid #999;
  border-right: 2px solid #999;
  height: 10px;
  width: 10px;
}
