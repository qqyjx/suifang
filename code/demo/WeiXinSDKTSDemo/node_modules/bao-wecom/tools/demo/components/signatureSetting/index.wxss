.bcom-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.bcom-multi-ellipsis--l2 {
  -webkit-line-clamp: 2;
}
.bcom-multi-ellipsis--l2,
.bcom-multi-ellipsis--l3 {
  -webkit-box-orient: vertical;
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
}
.bcom-multi-ellipsis--l3 {
  -webkit-line-clamp: 3;
}
.bcom-clearfix:after {
  clear: both;
  content: "";
  display: table;
}
.bcom-hairline,
.bcom-hairline--bottom,
.bcom-hairline--left,
.bcom-hairline--right,
.bcom-hairline--surround,
.bcom-hairline--top,
.bcom-hairline--top-bottom {
  position: relative;
}
.bcom-hairline--bottom:after,
.bcom-hairline--left:after,
.bcom-hairline--right:after,
.bcom-hairline--surround:after,
.bcom-hairline--top-bottom:after,
.bcom-hairline--top:after,
.bcom-hairline:after {
  border: 0 solid #ebedf0;
  bottom: -50%;
  box-sizing: border-box;
  content: " ";
  left: -50%;
  pointer-events: none;
  position: absolute;
  right: -50%;
  top: -50%;
  transform: scale(0.5);
  transform-origin: center;
}
.bcom-hairline--top:after {
  border-top-width: 1px;
}
.bcom-hairline--left:after {
  border-left-width: 1px;
}
.bcom-hairline--right:after {
  border-right-width: 1px;
}
.bcom-hairline--bottom:after {
  border-bottom-width: 1px;
}
.bcom-hairline--top-bottom:after {
  border-width: 1px 0;
}
.bcom-hairline--surround:after {
  border-width: 1px;
}
.bubble {
  position: relative;
  overflow: hidden;
}
.bubble:after {
  content: "";
  background: rgba(0, 0, 0, 0.3);
  position: absolute;
  width: 750rpx;
  height: 750rpx;
  left: calc(-325%);
  top: calc(-325%);
  opacity: 0;
  margin: auto;
  border-radius: 50%;
  transform: scale(1);
  transition: all 0.4s ease-in-out;
}
.bubble:active:after {
  transform: scale(0);
  opacity: 1;
  transition: 0s;
}
.setting-win-c {
  position: fixed;
  z-index: 99;
  left: 0;
  top: 0;
  width: 100vw;
  height: 100vh;
  background-color: rgba(0, 0, 0, 0.4);
}
.setting-win-c .setting-content-c {
  position: absolute;
  left: 0;
  top: 0;
  width: 375px;
  height: 100vh;
  background-color: #fff;
  display: flex;
  flex-direction: column;
}
.setting-win-c .setting-content-c .top-header-c {
  height: 40px;
  display: flex;
  align-items: center;
  box-shadow: 0 0 4px 0 #dfdfdf;
}
.setting-win-c .setting-content-c .top-header-c .btn {
  height: 100%;
  width: 60px;
  text-align: center;
  line-height: 40px;
  color: #0089FF;
}
.setting-win-c .setting-content-c .top-header-c .t {
  flex: 1;
  font-size: 18px;
  color: #333;
  text-align: center;
  line-height: 40px;
}
.setting-win-c .setting-content-c .title {
  height: 40px;
  font-size: 18px;
  color: #333;
  text-align: center;
  line-height: 40px;
  box-shadow: 0 0 4px 0 #dfdfdf;
}
.setting-win-c .setting-content-c .setting-form-c {
  flex: 1;
  padding: 0 10px;
  overflow-y: auto;
}
.setting-win-c .setting-content-c .setting-form-c .setting-form-item-c {
  display: flex;
  height: 40px;
  align-items: center;
  border-bottom: 1px solid #efefef;
}
.setting-win-c .setting-content-c .setting-form-c .setting-form-item-c .label {
  font-size: 14px;
  color: #666;
  white-space: nowrap;
}
.setting-win-c .setting-content-c .setting-form-c .setting-form-item-c .input-c {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  align-items: center;
}
.setting-win-c .setting-content-c .setting-form-c .setting-form-item-c .input-c .color-picker {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  width: 100%;
}
.setting-win-c .setting-content-c .setting-form-c .setting-form-item-c .input-c .color-picker .cur-color {
  width: 40px;
  height: 20px;
  border: 1px solid #ccc;
}
.setting-win-c .setting-content-c .setting-form-c .setting-form-item-c .input-c .color-picker .p-c {
  font-size: 14px;
  color: #ccc;
}
.setting-win-c .setting-content-c .setting-form-c .setting-form-item-c .input-c .silder-input {
  width: 220px;
}
.setting-win-c .setting-content-c .bottom-btn-c {
  height: 60px;
  box-shadow: 0 0 4px 0 #dfdfdf;
  display: flex;
  align-items: center;
  padding: 0 20px;
}
.setting-win-c .setting-content-c .bottom-btn-c .btn {
  flex: 1;
  margin-right: 20px;
  text-align: center;
  height: 40px;
  line-height: 40px;
  border: 1px solid #0089FF;
  border-radius: 4px;
  background-color: #0089FF;
  color: #fff;
  box-sizing: border-box;
}
.setting-win-c .setting-content-c .bottom-btn-c .btn:last-child {
  margin-right: 0;
}
.setting-win-c .setting-content-c .bottom-btn-c .btn.cancel {
  color: #0089FF;
  background-color: #fff;
}
