<view class="page-c" style="background-color: {{_backgroundColor || '#ffa500'}};">
  <view class="top-title" wx:if="{{title}}">{{title}}</view>
  <view class="hand-c">
  <view class="canvas-c">
    <canvas type="2d" class="canvas" disable-scroll="true" bindtouchstart="uploadScaleStart" bindtouchmove="uploadScaleMove"
      bindtouchend="uploadScaleEnd" bindtap="mouseDown" id="handWriting">
    </canvas>
  </view>
  </view>
  <view class="bottom-btn-c">
    <block wx:for="{{buttonList}}" wx:key="*this">
        <view catchtap="cancelTap" wx:key="*this" wx:if="{{item === 'cancel'}}" class="btn bubble reset">取消</view>
        <view catchtap="settingShow" wx:key="*this" wx:elif="{{item === 'setting'}}" class="btn bubble reset">设置</view>
        <view catchtap="retDraw" wx:key="*this" wx:elif="{{item === 'reset'}}" class="btn bubble reset">重写</view>
        <view catchtap="previewCanvasImg" wx:key="*this" wx:elif="{{item === 'preview'}}" class="btn bubble reset">预览</view>
        <view catchtap="subCanvas" wx:key="*this" wx:elif="{{item === 'save'}}" class="btn bubble">保存</view>
        <view catchtap="confirmTap" wx:key="*this" wx:elif="{{item === 'confirm'}}" class="btn bubble">确定</view>
    </block>
    
  </view>
  <signature-setting wx:if="{{isShowSetting}}" default-data="{{defaultData}}" bindcancel="settingCancel" bindconfirm="settingConfirm"></signature-setting>
</view>
