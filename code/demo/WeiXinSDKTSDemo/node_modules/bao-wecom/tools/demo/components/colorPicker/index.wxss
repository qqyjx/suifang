.color-picker-win-mask {
  position: fixed;
  width: 100vw;
  height: 100vh;
  left: 0;
  top: 0;
  z-index: 1001;
  background-color: rgba(0, 0, 0, 0.4);
}
.color-picker-win-c {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 1002;
  background-color: #fff;
  box-shadow: 0 2px 6px 0 rgba(0, 0, 0, 0.1);
  border-radius: 5px 5px 0 0;
  transition: all 0.2s linear;
  transform: translateY(100%);
}
.color-picker-win-c.show {
  transform: translateY(0);
}
.color-picker-win-c .color-picker-top-header-c {
  height: 40px;
  display: flex;
  align-items: center;
  box-shadow: 0 0 4px 0 #dfdfdf;
}
.color-picker-win-c .color-picker-top-header-c .btn {
  height: 100%;
  width: 60px;
  font-size: 14px;
  text-align: center;
  line-height: 40px;
  color: #0089FF;
}
.color-picker-win-c .color-picker-top-header-c .t {
  flex: 1;
  color: #333;
  font-size: 14px;
  text-align: center;
  line-height: 40px;
}
.color-picker-win-c .color-picker-bottom-c {
  width: 320px;
  margin: 0 auto;
  display: flex;
  padding: 10px 20px 15px;
  box-sizing: border-box;
}
.color-picker-win-c .color-picker-bottom-c .left-c {
  padding-top: 10px;
  padding-right: 10px;
  flex: 1;
}
.color-picker-win-c .color-picker-bottom-c .left-c .color-list-c {
  display: flex;
  flex-wrap: wrap;
}
.color-picker-win-c .color-picker-bottom-c .left-c .color-list-c .color-item {
  width: 20px;
  height: 20px;
  margin-right: 6px;
  margin-bottom: 6px;
  border: 1px solid #dfdfdf;
  box-sizing: border-box;
}
.color-picker-win-c .color-picker-bottom-c .left-c .color-list-c .color-item.on {
  border: 1px solid #0089FF;
  box-shadow: 0 0 4px 0 #0089FF;
}
.color-picker-win-c .color-picker-bottom-c .left-c .cur-color {
  width: 98px;
  height: 25px;
  margin-top: 10px;
  font-size: 12px;
  color: #fff;
  text-align: center;
  line-height: 25px;
  border: 1px solid #dfdfdf;
  box-sizing: border-box;
}
.color-picker-win-c .color-picker-bottom-c .left-c .num-show-c {
  display: flex;
  margin-top: 10px;
}
.color-picker-win-c .color-picker-bottom-c .left-c .num-show-c .num-show-item-c {
  flex: 1;
  font-size: 12px;
}
.color-picker-win-c .color-picker-bottom-c .left-c .num-show-c .num-show-item-c .num-val {
  line-height: 22px;
}
.color-picker-win-c .color-picker-bottom-c .right-c .ribbon {
  background: -webkit-linear-gradient(left, #f00 0%, #ff0 17%, #0f0 33%, #0ff 50%, #00f 67%, #f0f 83%, #ff0000 100%);
  width: 160px;
  margin: 10px 0 15px;
}
.color-picker-win-c .color-picker-bottom-c .right-c .color-picker-target {
  width: 160px;
  height: 160px;
  position: relative;
}
.color-picker-win-c .color-picker-bottom-c .right-c .color-picker-target .white {
  position: absolute;
  left: 0;
  top: 0;
  z-index: 9;
  right: 0;
  bottom: 0;
}
.color-picker-win-c .color-picker-bottom-c .right-c .color-picker-target .black {
  position: absolute;
  left: 0;
  top: 0;
  z-index: 10;
  right: 0;
  bottom: 0;
}
.color-picker-win-c .color-picker-bottom-c .right-c .color-picker-target .dot {
  width: 14px;
  height: 14px;
  border: 1px solid #dfdfdf;
  box-sizing: border-box;
  background-color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 11;
  position: relative;
}
.color-picker-win-c .color-picker-bottom-c .right-c .color-picker-target .dot::before {
  content: "";
  height: 1px;
  width: 6px;
  background-color: #dfdfdf;
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
}
.color-picker-win-c .color-picker-bottom-c .right-c .color-picker-target .dot::after {
  content: "";
  height: 6px;
  width: 1px;
  background-color: #dfdfdf;
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
}
