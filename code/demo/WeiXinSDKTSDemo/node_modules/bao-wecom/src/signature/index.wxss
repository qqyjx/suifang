.bcom-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.bcom-multi-ellipsis--l2 {
  -webkit-line-clamp: 2;
}
.bcom-multi-ellipsis--l2,
.bcom-multi-ellipsis--l3 {
  -webkit-box-orient: vertical;
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
}
.bcom-multi-ellipsis--l3 {
  -webkit-line-clamp: 3;
}
.bcom-clearfix:after {
  clear: both;
  content: "";
  display: table;
}
.bcom-hairline,
.bcom-hairline--bottom,
.bcom-hairline--left,
.bcom-hairline--right,
.bcom-hairline--surround,
.bcom-hairline--top,
.bcom-hairline--top-bottom {
  position: relative;
}
.bcom-hairline--bottom:after,
.bcom-hairline--left:after,
.bcom-hairline--right:after,
.bcom-hairline--surround:after,
.bcom-hairline--top-bottom:after,
.bcom-hairline--top:after,
.bcom-hairline:after {
  border: 0 solid #ebedf0;
  bottom: -50%;
  box-sizing: border-box;
  content: " ";
  left: -50%;
  pointer-events: none;
  position: absolute;
  right: -50%;
  top: -50%;
  transform: scale(0.5);
  transform-origin: center;
}
.bcom-hairline--top:after {
  border-top-width: 1px;
}
.bcom-hairline--left:after {
  border-left-width: 1px;
}
.bcom-hairline--right:after {
  border-right-width: 1px;
}
.bcom-hairline--bottom:after {
  border-bottom-width: 1px;
}
.bcom-hairline--top-bottom:after {
  border-width: 1px 0;
}
.bcom-hairline--surround:after {
  border-width: 1px;
}
.bubble {
  position: relative;
  overflow: hidden;
}
.bubble:after {
  content: "";
  background: rgba(0, 0, 0, 0.3);
  position: absolute;
  width: 750rpx;
  height: 750rpx;
  left: calc(-325%);
  top: calc(-325%);
  opacity: 0;
  margin: auto;
  border-radius: 50%;
  transform: scale(1);
  transition: all 0.4s ease-in-out;
}
.bubble:active:after {
  transform: scale(0);
  opacity: 1;
  transition: 0s;
}
.page-c {
  height: 100vh;
  width: 100vw;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  position: relative;
}
.page-c .top-title {
  color: #666;
  font-size: 16px;
  font-weight: bold;
  text-align: center;
  height: 40px;
  line-height: 40px;
}
.page-c .hand-c {
  flex: 1;
  padding: 10px 20px 0;
  box-sizing: border-box;
  width: 100vw;
  overflow: hidden;
  z-index: 0;
}
.page-c .hand-c .canvas-c {
  width: 100%;
  height: 100%;
  overflow: hidden;
  border: 1px dashed #ff0000;
}
.page-c .hand-c .canvas-c .canvas {
  width: 100%;
  height: 100%;
}
.page-c .bottom-btn-c {
  height: 50px;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 0 20px;
}
.page-c .bottom-btn-c .btn {
  height: 24px;
  padding: 0 12px;
  border-radius: 5px;
  line-height: 24px;
  font-size: 12px;
  background-color: #008ef6;
  color: #fff;
  margin-left: 10px;
  border: 1px solid #008ef6;
}
.page-c .bottom-btn-c .btn.reset {
  background-color: #fff;
  color: #008ef6;
}
