<view class="color-picker-win-mask" wx:if="{{show}}" catch:tap="maskTap"></view>
<view class="color-picker-win-c custom-class {{show ? 'show' : ''}}">
    <view class="color-picker-top-header-c">
        <view class="btn cancel bubble" catch:tap="cancelTap">{{cancelText}}</view>
        <view class="t">{{title || ""}}</view>
        <view class="btn bubble" catch:tap="confirmTap">{{comfirmText}}</view>
    </view>
    <view class="color-picker-bottom-c">
        <view class="left-c">
            <view class="color-list-c">
                <view class="color-item {{colorHex == item ? 'on' : ''}}" wx:if="{{index < 12}}" data-color="{{item}}" catch:tap="chooseColor" wx:for="{{selectColorList}}" wx:key="*this" style="background-color: {{item}}"></view>
            </view>
            <view class="cur-color" style="background-color: {{colorHex}};color: {{colorHex == '#ffffff' ? '#ffa600' : '#ffffff'}};">{{colorHex}}</view>
            <view class="num-show-c">
                <view class="num-show-item-c">
                    <view class="num-val">R: {{colorRgb.r}}</view>
                    <view class="num-val">G: {{colorRgb.g}}</view>
                    <view class="num-val">B: {{colorRgb.b}}</view>
                </view>
                <view class="num-show-item-c">
                    <view class="num-val">H: {{colorHsv.h}}</view>
                    <view class="num-val">S: {{colorHsv.s}}</view>
                    <view class="num-val">V: {{colorHsv.v}}</view>
                </view>
            </view>
        </view>
        <view class="right-c">
            <slider bindchanging="changeHue" bindchange="changeHue" block-size="25" activeColor="transparent" backgroundColor="transparent" class="ribbon" max="360" value="{{colorHsv.h}}" bindtouchend="onEnd" />
            <movable-area class="color-picker-target" catch:tap="areaTap" style="background-color: rgba({{hueColor.r}}, {{hueColor.g}}, {{hueColor.b}}, 1)">
                <view class="white" style="background:linear-gradient(to right, rgba(255,255,255,1), rgba({{hueColor.r}}, {{hueColor.g}}, {{hueColor.b}}, 0));"></view>
                <view class="black" style="background:linear-gradient(to top, rgba(0,0,0,1), rgba({{hueColor.r}}, {{hueColor.g}}, {{hueColor.b}}, 0));">
                </view>
                <movable-view direction="all" bindchange="changeSV" x="{{x}}" y="{{y}}" animation="{{false}}" class="dot"></movable-view>
            </movable-area>
        </view>
    </view>
</view>