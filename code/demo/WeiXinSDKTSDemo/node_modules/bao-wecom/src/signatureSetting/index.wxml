<view class="setting-win-c" catch:tap="cancelTap">
    <view class="setting-content-c" catch:tap="empty">
        <view class="top-header-c">
            <view class="btn cancel bubble" catch:tap="cancelTap">取消</view>
            <view class="t">设置</view>
            <view class="btn bubble" catch:tap="confirmTap">确定</view>
        </view>
        <!-- <view class="title">设置</view> -->
        <view class="setting-form-c">
            <view class="setting-form-item-c">
                <view class="label">背景色：</view>
                <view class="input-c">
                    <view class="color-picker" data-title="请选择背景色" data-color="{{backgroundColor}}" data-name="backgroundColor" catch:tap="showColorPicker">
                        <view class="cur-color" style="background-color: {{backgroundColor}};" wx:if="{{backgroundColor}}"></view>
                        <view class="p-c" wx:else>请选择</view>
                    </view>
                </view>
            </view>
            <view class="setting-form-item-c">
                <view class="label">画板色：</view>
                <view class="input-c">
                    <view class="color-picker" data-title="请选择画板色" data-color="{{boardColor}}" data-name="boardColor" catch:tap="showColorPicker">
                        <view class="cur-color" style="background-color: {{boardColor}};" wx:if="{{boardColor}}"></view>
                        <view class="p-c" wx:else>请选择</view>
                    </view>
                </view>
            </view>
            <view class="setting-form-item-c">
                <view class="label">线条色：</view>
                <view class="input-c">
                    <view class="color-picker" data-title="请选择线条色" data-color="{{color}}" data-name="color" catch:tap="showColorPicker">
                        <view class="cur-color" style="background-color: {{color}};" wx:if="{{color}}"></view>
                        <view class="p-c" wx:else>请选择</view>
                    </view>
                </view>
            </view>
            <view class="setting-form-item-c">
                <view class="label">线条粗细：</view>
                <view class="input-c">
                    <slider class="silder-input" min="{{1}}" max="{{30}}" value="{{size}}" show-value selected-color="#008ef6" block-size="{{20}}" bindchange="lineSizeChange"></slider>
                </view>
            </view>
        </view>
        <!-- <view class="bottom-btn-c">
            <view class="btn cancel bubble" catch:tap="cancelTap">取消</view>
            <view class="btn bubble" catch:tap="confirmTap">确定</view>
        </view> -->
        <color-picker show="{{isShowColor}}" title="{{colorPickerTitle}}" bindconfirm="colorConfirm" bindcancel="colorCancel" bindmask="colorCancel" color="{{initColor}}"></color-picker>

    </view>
</view>
