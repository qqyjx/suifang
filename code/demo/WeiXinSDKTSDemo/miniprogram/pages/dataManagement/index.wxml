<!--pages/dataManagement/index.wxml-->
<view class="container">
  <view class="header">
    <text class="title">健康数据管理</text>
    <text class="subtitle">智能随访数据中心</text>
  </view>

  <!-- HTTP同步状态 -->
  <view class="sync-status">
    <view class="status-item">
      <text class="status-label">HTTP同步:</text>
      <text class="status-value {{httpSyncEnabled ? 'enabled' : 'disabled'}}">
        {{httpSyncEnabled ? '已启用' : '已禁用'}}
      </text>
    </view>
    <view class="status-item">
      <text class="status-label">服务器:</text>
      <text class="status-value">{{serverUrl}}</text>
    </view>
  </view>

  <!-- 日期列表 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">数据记录 (按日期)</text>
      <text class="section-count">共 {{dateList.length}} 天</text>
    </view>
    <view class="date-list" wx:if="{{dateList.length > 0}}">
      <view class="date-item" wx:for="{{dateList}}" wx:key="date" bindtap="viewDateDetail" data-date="{{item.date}}">
        <view class="date-info">
          <text class="date-text">{{item.date}}</text>
          <text class="date-count">{{item.dataTypes.length}} 种数据</text>
        </view>
        <view class="data-types">
          <text class="type-tag" wx:for="{{item.dataTypes}}" wx:key="*this" wx:for-item="type">{{type}}</text>
        </view>
        <text class="arrow">></text>
      </view>
    </view>
    <view class="empty-tip" wx:else>
      <text>暂无数据记录</text>
      <text class="sub-tip">连接设备采集健康数据后将在此显示</text>
    </view>
  </view>

  <!-- 当日数据详情 -->
  <view class="section" wx:if="{{selectedDate}}">
    <view class="section-header">
      <text class="section-title">{{selectedDate}} 数据详情</text>
      <text class="close-btn" bindtap="closeDetail">关闭</text>
    </view>
    <view class="data-detail">
      <view class="detail-item" wx:for="{{selectedDateData}}" wx:key="type">
        <view class="detail-header">
          <text class="detail-type">{{item.typeName}}</text>
          <text class="detail-count">{{item.records.length}} 条记录</text>
        </view>
        <view class="record-list">
          <view class="record-item" wx:for="{{item.records}}" wx:key="timestamp" wx:for-item="record">
            <text class="record-time">{{record.timestamp}}</text>
            <text class="record-value">{{record.displayValue}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-buttons">
    <button class="action-btn primary" bindtap="exportAllData">
      导出全部数据
    </button>
    <button class="action-btn" bindtap="syncToServer">
      同步到服务器
    </button>
    <button class="action-btn" bindtap="refreshData">
      刷新数据
    </button>
    <button class="action-btn danger" bindtap="clearAllData">
      清除所有数据
    </button>
  </view>

  <!-- 导出结果 -->
  <view class="export-result" wx:if="{{exportResult}}">
    <view class="result-header">
      <text class="result-title">导出结果</text>
      <text class="close-btn" bindtap="closeExportResult">关闭</text>
    </view>
    <scroll-view class="result-content" scroll-y>
      <text class="result-text">{{exportResult}}</text>
    </scroll-view>
    <view class="result-actions">
      <button class="small-btn" bindtap="copyExportResult">复制到剪贴板</button>
      <button class="small-btn" bindtap="shareExportResult">分享文件</button>
    </view>
  </view>
</view>
